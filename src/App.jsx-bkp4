 // g.font="bold 24px monospace"; g.fillStyle="rgba(140,6,6,.7)"; g.fillText("nie wychodź  nie wychodź",256,90);
 // g.font="18px monospace"; g.fillStyle="rgba(120,5,5,.5)"; g.fillText("WRÓĆ  WRÓĆ  WRÓĆ  WRÓĆ",256,122);
 // g.font="14px monospace"; g.fillStyle="rgba(100,4,4,.4)"; g.fillText("zostań zostań zostań",256,150);
 // g.strokeStyle="rgba(140,5,5,.35)"; g.lineWidth=2.5;
  g.beginPath(); g.moveTo(55,52); g.lineTo(48,200); g.stroke();
