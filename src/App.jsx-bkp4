// ─── CANVAS TEXTURES ───────────────────────────────────────────────────────

function mkWall() {
  // Ciemna boazeria - dolna cześć oliwkowe panele, górna farba
  const c = document.createElement("canvas"); c.width=512; c.height=512;
  const g = c.getContext("2d");
  // Dół - ciemne panele laminatowe oliwkowo-szare (ok 60% wysokości)
  g.fillStyle="#50574A"; g.fillRect(0,0,512,308);
  for(let i=0;i<60;i++){
    const x=Math.random()*512;
    g.strokeStyle=`rgba(20,25,15,${.04+Math.random()*.08})`;
    g.lineWidth=1+Math.random()*1.5;
    g.beginPath(); g.moveTo(x,0); g.lineTo(x+Math.random()*6-3,308); g.stroke();
  }
  for(let x=0;x<512;x+=68){
    const gr=g.createLinearGradient(x,0,x+68,0);
    gr.addColorStop(0,"rgba(255,255,255,0)");
    gr.addColorStop(.45,"rgba(255,255,255,.05)");
    gr.addColorStop(1,"rgba(255,255,255,0)");
    g.fillStyle=gr; g.fillRect(x,0,68,308);
  }
  // Górna - matowa farba
  g.fillStyle="#8C7C5C"; g.fillRect(0,308,512,204);
  for(let i=0;i<600;i++){
    g.fillStyle=`rgba(60,50,25,${Math.random()*.05})`;
    g.fillRect(Math.random()*512,308+Math.random()*204,Math.random()*4,Math.random()*3);
  }
  // Listwa podziałowa
  g.fillStyle="#1A1208"; g.fillRect(0,300,512,14);
  g.fillStyle="#3A2810"; g.fillRect(0,302,512,8);
  // Cokół
  g.fillStyle="#151008"; g.fillRect(0,492,512,20);
  g.fillStyle="#2E2010"; g.fillRect(0,494,512,10);
  // Pionowe listwy paneli
  for(let x=0;x<=512;x+=68){
    g.fillStyle="#1A1208"; g.fillRect(x-3,0,5,308);
    g.fillStyle="rgba(90,70,25,.25)"; g.fillRect(x+1,0,2,308);
  }
  return c;
}

function mkWallpaper() { return mkWall(); }

function mkFloor() {
  const c = document.createElement("canvas"); c.width=512; c.height=512;
  const g = c.getContext("2d");
  g.fillStyle="#C8B078"; g.fillRect(0,0,512,512);
  const colors=["#C8A860","#D4B870","#BCA058","#CEAD68","#B89850"];
  const W2=24, H2=10;
  for(let row=-40;row<60;row++){
    for(let col=-5;col<40;col++){
      const x=col*W2*1.414-row*(H2+W2)*.2;
      const y=row*(W2+H2)*.2+col*W2*.1;
      g.save(); g.translate(x,y); g.rotate(Math.PI/4);
      g.fillStyle=colors[Math.abs(row*3+col*2)%5];
      g.fillRect(0,0,W2,H2);
      g.strokeStyle="rgba(80,55,20,.3)"; g.lineWidth=.6;
      g.strokeRect(0,0,W2,H2);
      g.restore();
    }
  }
  for(let i=0;i<150;i++){
    g.strokeStyle="rgba(60,40,15,"+(.05+Math.random()*.1)+")";
    g.lineWidth=.5;
    const x=Math.random()*512, y=Math.random()*512;
    g.beginPath(); g.moveTo(x,y); g.lineTo(x+Math.random()*18-9,y+Math.random()*18-9); g.stroke();
  }
  return c;
}

function mkCeil() {
  const c = document.createElement("canvas"); c.width=512; c.height=512;
  const g = c.getContext("2d");
  g.fillStyle="#D5C8A4"; g.fillRect(0,0,512,512);
  for(let i=0;i<300;i++){
    g.fillStyle="rgba(90,75,45,"+(Math.random()*.035)+")";
    g.fillRect(Math.random()*512,Math.random()*512,Math.random()*5,Math.random()*4);
  }
  return c;
}

function mkCarpet(v) {
  const c = document.createElement("canvas"); c.width=256; c.height=256;
  const g = c.getContext("2d");
  const bgs=["#7A1A08","#1A4A1A","#1A1A6A","#8B4A00","#6A0A5A"];
  const fgs=[["#D4821A","#F0C060","#C84020"],["#A0D040","#F0E840","#60A820"],
             ["#4080D0","#F0C040","#A020A0"],["#D4A040","#C04020","#F0E060"],
             ["#F040A0","#F0E040","#40A0F0"]];
  g.fillStyle=bgs[v%5]; g.fillRect(0,0,256,256);
  const sz=32,cols=fgs[v%5];
  for(let y=-sz;y<256+sz;y+=sz) for(let x=-sz;x<256+sz;x+=sz){
    const ci=(Math.floor(x/sz)+Math.floor(y/sz))%cols.length;
    g.save(); g.translate(x+(Math.floor(y/sz)%2)*sz/2,y); g.rotate(Math.PI/4);
    g.fillStyle=cols[ci]; g.fillRect(-sz*.38,-sz*.38,sz*.76,sz*.76); g.restore();
    g.save(); g.translate(x+(Math.floor(y/sz)%2)*sz/2+sz/2,y+sz/2); g.rotate(Math.PI/4);
    g.fillStyle=cols[(ci+1)%cols.length]; g.fillRect(-sz*.2,-sz*.2,sz*.4,sz*.4); g.restore();
  }
  g.strokeStyle="#F0C060"; g.lineWidth=4; g.strokeRect(6,6,244,244);
  g.strokeStyle="rgba(240,192,96,.5)"; g.lineWidth=2; g.strokeRect(12,12,232,232);
  return c;
}

